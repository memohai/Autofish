{
  "name": "amctl-cli",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic CLI executor for amctl REST API",
  "type": "module",
  "bin": {
    "amc": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "agentfs-sdk": "^0.6.2",
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
