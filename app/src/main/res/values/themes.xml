<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Amctl" parent="Theme.Material3.DayNight.NoActionBar" />

    <style name="Theme.Amctl.Light" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowBackground">@color/amctl_light_background</item>
    </style>

    <style name="Theme.Amctl.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@color/amctl_dark_background</item>
    </style>

    <!-- Fixed launch background to prevent visible black/white jump on startup. -->
    <style name="Theme.Amctl.Launch" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/amctl_launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/amctl_launch_background</item>
    </style>
</resources>
